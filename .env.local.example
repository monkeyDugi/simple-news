# Simple News — 로컬 개발용 환경변수 예시
# 실제 값은 .env.local 에 채우고, .env.local 은 절대 커밋 금지!

# ─── Supabase ────────────────────────────────────────────────
# Supabase 대시보드 → Settings → API Keys
#   - Publishable key  → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   - Secret key       → SUPABASE_SECRET_KEY
# 로컬 개발용은 `supabase start` 출력에서 복사.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_key_here

# ─── AWS Bedrock — Anthropic Sonnet 4.6 (AI 요약) ────────────────
# AWS 콘솔 → Bedrock → API Keys 에서 발급. region 별로 모델 access 활성화 필요.
# 모델: global.anthropic.claude-sonnet-4-6 (cross-region inference profile)
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here
AWS_REGION=ap-northeast-2

# ─── API base URL ─────────────────────────────────────────
# .env (로컬 dev 기본값) 과 .env.production (프로덕션/Android 빌드) 으로 관리.
# .env.local 에는 넣지 않을 것 — 모든 빌드를 덮어써서 Android 빌드가 깨짐.

# ─── 외부 의존성 모킹 토글 ────────────────────────────────────
# true: lib/mocks/* 의 fixture 사용 (네트워크 호출 없음)
# false: 실제 외부 서비스 호출 (해당 키들이 채워져 있어야 함)
# 키가 비어 있으면 코드가 자동으로 모킹으로 fallback (보호 장치).
MOCK_SUPABASE=false
MOCK_LLM=false
MOCK_SCRAPER=false
