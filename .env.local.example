# Simple News — 로컬 개발용 환경변수 예시
# 실제 값은 .env.local 에 채우고, .env.local 은 절대 커밋 금지!

# ─── Supabase ────────────────────────────────────────────────
# Supabase 대시보드 → Settings → API Keys
#   - Publishable key  → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   - Secret key       → SUPABASE_SECRET_KEY
# 로컬 개발용은 `supabase start` 출력에서 복사.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_key_here

# ─── OpenAI (AI 요약) ─────────────────────────────────────────
# https://platform.openai.com/api-keys
# 모델: gpt-4o-mini (저비용 + 한국어 우수). Usage limit / Prepaid 한도 같이 걸어 두는 것을 권장.
OPENAI_API_KEY=your_openai_api_key_here
SUMMARIZE_BATCH_SIZE=20

# ─── Cron 인증 ─────────────────────────────────────────────
# 임의 32자 이상 랜덤 문자열 — `openssl rand -hex 32` 로 생성
CRON_SECRET=replace_with_random_hex_string

# ─── API base URL ─────────────────────────────────────────
# 로컬: http://localhost:3000
# 프로덕션: https://simple-news.vercel.app (실제 도메인으로)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ─── 외부 의존성 모킹 토글 ────────────────────────────────────
# true: lib/mocks/* 의 fixture 사용 (네트워크 호출 없음)
# false: 실제 외부 서비스 호출 (해당 키들이 채워져 있어야 함)
# 키가 비어 있으면 코드가 자동으로 모킹으로 fallback (보호 장치).
MOCK_SUPABASE=false
MOCK_OPENAI=false
MOCK_SCRAPER=false
