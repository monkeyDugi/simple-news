# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# 의존성
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 테스트 커버리지
/coverage

# Next.js 빌드 산출물
.next/
out/
build/
dist/

# 환경변수 — 절대 커밋 금지! (단, *.example은 커밋 허용)
.env*
!.env.local.example
!.env.example

# 로그
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# 에디터
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# 인증서
*.pem

# Supabase 로컬 (Docker 볼륨)
supabase/.branches
supabase/.temp

# Capacitor (12단계에서 의미 생김)
android/app/src/main/assets/public
android/app/build/
android/build/
android/.gradle/
android/local.properties
*.keystore
*.jks

# TypeScript 캐시
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel
